{% extends 'forms-processor/_layouts/cp' %}

{% set title = 'Form Types' %}
{% set selectedSubnavItem = 'form-types' %}

{% block actionButton %}
<a href="{{ url('forms-processor/form-types/new') }}" class="btn submit add icon">
    {{ 'New Form Type'|t('forms-processor') }}
</a>
{% endblock %}

{% block content %}
{% if formTypes|length %}
<table class="data fullwidth collapsible">
    <thead>
        <tr>
            <th>{{ 'Name'|t('forms-processor') }}</th>
            <th>{{ 'Handle'|t('forms-processor') }}</th>
            <th>{{ 'Slate Source'|t('forms-processor') }}</th>
            <th>{{ 'PDF Template'|t('forms-processor') }}</th>
            <th class="thin">{{ 'Enabled'|t('forms-processor') }}</th>
            <th class="thin"></th>
        </tr>
    </thead>
    <tbody>
        {% for formType in formTypes %}
        <tr>
            <td>
                <a href="{{ url('forms-processor/form-types/' ~ formType.id) }}">
                    <strong>{{ formType.name }}</strong>
                </a>
            </td>
            <td><code>{{ formType.handle }}</code></td>
            <td>{{ formType.slateSource ?: '—' }}</td>
            <td>
                {% if formType.pdfTemplateId %}
                    <a href="{{ url('forms-processor/pdf-templates/' ~ formType.pdfTemplateId) }}">Template #{{ formType.pdfTemplateId }}</a>
                {% else %}
                    <span class="light">—</span>
                {% endif %}
            </td>
            <td class="thin centeralign">
                {% if formType.enabled %}
                    <span class="status on"></span>
                {% else %}
                    <span class="status"></span>
                {% endif %}
            </td>
            <td class="thin">
                <a class="delete icon" title="{{ 'Delete'|t('app') }}"
                   href="#"
                   data-id="{{ formType.id }}"
                   data-confirm="{{ 'Are you sure you want to delete this form type and all its submissions?'|t('forms-processor') }}"
                   data-action="forms-processor/form-types/delete"></a>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% else %}
<p class="zilch">{{ 'No form types yet.'|t('forms-processor') }}
    <a href="{{ url('forms-processor/form-types/new') }}">{{ 'Create one'|t('forms-processor') }}</a>.
</p>
{% endif %}
{% endblock %}
